
@{
    ViewBag.Title = "Downloads";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h4 class="py-3 breadcrumb-wrapper mb-2">Downloads List</h4>

<!-- Latest Updates Table -->
<div class="card" id="latestupdatesTable">
    <div class="card-datatable table-responsive">
        <table class="datatables-latestupdates table border-top">
            <thead>
                <tr>
                    <th></th>
                    <th></th>
                    <th>Title</th>
                    <th>Created Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<!-- Latest Updates Table -->
<div class="modal fade" id="latestUpdateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-3 p-md-5">
            <button type="button" class="btn-close btn-pinned" data-bs-dismiss="modal" aria-label="Close"></button>
            <div class="modal-body">

            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        $(function () {
            LoadTable();
        });

        function LoadTable() {
            var e,
            a = $(".datatables-latestupdates")
            a.DataTable().destroy();
            a.length &&
                (e = a.DataTable({
                    "ajax": {
                        "url": "/LatestUpdate/GetLatestUpdate",
                        "type": "GET",
                        "datatype": "json"
                    },
                    columns: [
                        { data: "" },
                        { data: "LatestUpdatesKey" },
                        { data: "Title" },
                        { data: "CreatedOn" },
                        { data: "IsActive" },
                        { data: "" },
                    ],
                    columnDefs: [
                        {
                            className: "control",
                            orderable: !1,
                            searchable: !1,
                            responsivePriority: 2,
                            targets: 0,
                            render: function (e, a, t, s) {
                                return "";
                            },
                        },
                        { targets: 1, searchable: !1, visible: !1, orderable: 1},
                        {
                            targets: 2,
                            render: function (e, a, t, s) {
                                return (
                                    '<span class="text-nowrap fw-semibold">' + t.Title + "</span>"
                                );
                            },
                        },
                        {
                            targets: 3,
                            orderable: !1,
                            render: function (e, a, t, s) {
                                return '<span class="text-nowrap">' + ConvertJsonDateString(t.CreatedOn) + "</span>";
                            },
                        },
                        {
                            targets: 4,
                            searchable: !1,
                            orderable: !1,
                            render: function (e, a, t, s) {
                                var r = t.IsActive == true ? "<a href='javascript:void(0)' data-isactive='De-Activate' data-id=" + t.LatestUpdatesKey + " class='active-deactive'><span class='badge bg-label-primary m-1'>Disable</span></a>" : "<a href='javascript:void(0)' data-id=" + t.LatestUpdatesKey + " data-isactive='Activate' class='active-deactive'><span class='badge bg-label-warning m-1'>Enable</span></a>"
                                return '<span class="text-nowrap">' + r + "</span>";
                            },
                        },

                        {
                            targets: -1,
                            searchable: !1,
                            title: "Actions",
                            orderable: !1,
                            render: function (e, a, t, s) {
                                return '<span class="text-nowrap"><button class="edit-record btn btn-sm btn-icon me-2" data-bs-toggle="modal" data-bs-target="#latestUpdateModal"  data-id=' + t.LatestUpdatesKey + '><i class="bx bx-edit"></i></button><button class="btn btn-sm btn-icon delete-record" data-id=' + t.LatestUpdatesKey +'><i class="bx bx-trash"></i></button></span>';
                            },
                        },
                    ],
                    order: [[1, "desc"]],
                    dom: '<"row mx-1"<"col-sm-12 col-md-3" l><"col-sm-12 col-md-9"<"dt-action-buttons text-xl-end text-lg-start text-md-end text-start d-flex align-items-center justify-content-md-end justify-content-center flex-wrap me-1"<"me-3"f>B>>>t<"row mx-2"<"col-sm-12 col-md-6"i><"col-sm-12 col-md-6"p>>',
                    language: {
                        sLengthMenu: "_MENU_",
                        search: "Search",
                        searchPlaceholder: "Search..",
                    },
                    buttons: [
                        {
                            text: "Add Downloads",
                            className: "add-new btn btn-primary mb-3 mb-md-0",
                            attr: {
                                //  "data-bs-toggle": "modal",
                                "data-bs-target": "#latestUpdateModal",
                            },
                            init: function (e, a, t) {
                                $(a).removeClass("btn-secondary");
                            },
                        },
                    ],
                    //responsive: {
                    //    details: {
                    //        display: $.fn.dataTable.Responsive.display.modal({
                    //            header: function (e) {
                    //                return "Details of " + e.data().Title;
                    //            },
                    //        }),
                    //        type: "column",
                    //        renderer: function (e, a, t) {
                    //            t = $.map(t, function (e, a) {
                    //                return "" !== e.title
                    //                    ? '<tr data-dt-row="' +
                    //                    e.rowIndex +
                    //                    '" data-dt-column="' +
                    //                    e.columnIndex +
                    //                    '"><td>' +
                    //                    e.title +
                    //                    ":</td> <td>" +
                    //                    e.data +
                    //                    "</td></tr>"
                    //                    : "";
                    //            }).join("");
                    //            return !!t && $('<table class="table"/><tbody />').append(t);
                    //        },
                    //    },
                    //},
                })),
                $(".datatables-latestupdates tbody").on("click", ".active-deactive", function () {
                    var id = $(this).attr('data-id');
                    var statustext = $(this).attr('data-isactive');
                    Swal.fire({
                        title: "Are you sure want to " + statustext + "?",
                            text: "You won't be able to revert this!",
                            icon: "warning",
                            showCancelButton: !0,
                        confirmButtonText: "Yes, " + statustext +" it!",
                            customClass: {
                                confirmButton: "btn btn-primary me-3",
                                cancelButton: "btn btn-label-secondary",
                            },
                            buttonsStyling: !1,
                        }).then(function (t) {
                            if (t.isConfirmed) {
                                $.ajax({
                                    type: "GET",
                                     url: '@Url.Action("ActivateDeActivate", "LatestUpdate")',
                                    contentType: "application/json; charset=utf-8",
                                    data: {"LatestUpdatesKey": id},
                                    datatype: "json",
                                    success: function (data) {
                                        var txtmsg = statustext == "Activate" ? "Activated" :"De-Activated"
                                        t.value &&
                                        Swal.fire({
                                            icon: "success",
                                            title: txtmsg,
                                            text: "Your data has been " + txtmsg +".",
                                            customClass: { confirmButton: "btn btn-success" },
                                        });

                                        $('.swal2-confirm').on('click', function () { LoadTable() });
                                    },
                                    error: function () {
                                        alert("Error Occured!");
                                    }
                                });
                            }

                        });
                }),

                $(".datatables-latestupdates tbody").on("click", ".delete-record", function () {
                        var id = $(this).attr('data-id');
                        Swal.fire({
                            title: "Are you sure want to delete?",
                            text: "You won't be able to revert this!",
                            icon: "warning",
                            showCancelButton: !0,
                            confirmButtonText: "Yes, delete it!",
                            customClass: {
                                confirmButton: "btn btn-primary me-3",
                                cancelButton: "btn btn-label-secondary",
                            },
                            buttonsStyling: !1,
                        }).then(function (t) {
                            if (t.isConfirmed) {
                                $.ajax({
                                    type: "GET",
                                     url: '@Url.Action("DeleteLatestUpdate", "LatestUpdate")',
                                    contentType: "application/json; charset=utf-8",
                                    data: {"LatestUpdatesKey": id},
                                    datatype: "json",
                                    success: function (data) {
                                        t.value &&
                                        Swal.fire({
                                            icon: "success",
                                            title: "Deleted!",
                                            text: "Your data has been deleted.",
                                            customClass: { confirmButton: "btn btn-success" },
                                        });

                                        $('.swal2-confirm').on('click', function () { LoadTable() });
                                    },
                                    error: function () {
                                        alert("Data not deleted.");
                                    }
                                });
                            }

                        });
                }),

                $(".add-new").on("click", function () {
                    var options = { "backdrop": "static", keyboard: true };
                    $.ajax({
                        type: "GET",
                        url: '@Url.Action("AddLatestUpdate", "LatestUpdate")',
                        contentType: "application/json; charset=utf-8",
                        data: {},
                        datatype: "json",
                        success: function (data) {
                            $('.modal-body').html(data)
                            $('#latestUpdateModal').modal(options);
                            $('#latestUpdateModal').modal('show');
                        },
                        error: function () {
                            alert("Data load failed.");
                        }
                    });
                }),

                $(".datatables-latestupdates tbody").on(
                    "click",
                    ".edit-record", function () {
                    var options = { "backdrop": "static", keyboard: true };
                    var id = $(this).attr('data-id');
                    $.ajax({
                        type: "GET",
                        url: '@Url.Action("EditLatestUpdate", "LatestUpdate")',
                        contentType: "application/json; charset=utf-8",
                        data: {"LatestUpdatesKey": id},
                        datatype: "json",
                        success: function (data) {
                            $('.modal-body').html(data)
                            $('#latestUpdateModal').modal(options);
                            $('#latestUpdateModal').modal('show');
                        },
                        error: function () {
                            alert("Data load failed.");
                        }
                    });
                }),
                setTimeout(() => {
                    $(".dataTables_filter .form-control").removeClass("form-control-sm"),
                        $(".dataTables_length .form-select").removeClass("form-select-sm");
                }, 300);
    }
        function ConvertJsonDateString(jsonDate) {
            var shortDate = null;
            if (jsonDate) {
                var regex = /-?\d+/;
                var matches = regex.exec(jsonDate);
                var dt = new Date(parseInt(matches[0]));
                var month = dt.getMonth() + 1;
                var monthString = month > 9 ? month : '0' + month;
                var day = dt.getDate();
                var dayString = day > 9 ? day : '0' + day;
                var year = dt.getFullYear();
                shortDate = dayString + '-' + monthString + '-' + year;
            }
            return shortDate;
        };
    </script>

}