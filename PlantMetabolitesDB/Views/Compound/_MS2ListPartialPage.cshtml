@model IEnumerable<PlantMetabolitesDB.ViewModel.MS2MassSpectraViewModel>

<div class="mass-body" id="massTable">
    <div class="card-datatable table-responsive">
        <table class="datatables-mass table border-top">
            <thead>
                <tr>
                    @*<th></th>*@
                    <th class="visually-hidden"></th>
                    <th>Polarity</th>
                    <th>Annotation</th>
                    <th>Parent Ion</th>
                    <th>Data File</th>
                    <th>Ref. File</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>

                @if (Model.Count() > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="visually-hidden">>@item.MS2MassSpectraKey</td>
                            <td>@item.PolarityName</td>
                            <td>@item.AnnotationName</td>
                            <td>@item.ParentIon</td>
                            <td>

                                @{
                                    if (item.MS2DataFile != null)
                                    {
                                        <a href="~/UploadedFiles/MS2/DataFile/@item.MS2DataFile" target="_blank" class="btn btn-sm btn-secondary mt-2">
                                            <i class="bx bx-show-alt"></i> View
                                        </a>
                                    }
                                    else
                                    {
                                        <span>N/A</span>
                                    }
                                }

                            </td>
                            <td>
                                @{
                                    if (item.MS2RefFile != null)
                                    {
                                        <a href="~/UploadedFiles/MS2/RefFile/@item.MS2RefFile" target="_blank" class="btn btn-sm btn-secondary mt-2">
                                            <i class="bx bx-show-alt"></i> View
                                        </a>
                                    }
                                    else
                                    {
                                        <span>N/A</span>
                                    }
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-icon edit-record" data-id='@item.MS2MassSpectraKey' title="Edit"><i class="bx bx-edit"></i></button>
                                <button class="btn btn-sm btn-icon delete-record" data-id='@item.MS2MassSpectraKey' title="Delete"> <i class="bx bx-trash"></i></button>

                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>
    </div>
</div>
<script>
    $(function () {
        var a = $(".datatables-mass");
        a.DataTable().destroy();
        a.DataTable({
            'columnDefs': [{
                'targets': [0,1,2,3,4,5,6], /* column index */
                'orderable': false, /* true or false */
                'bSort': false,
            }]
        });

        $(".datatables-mass tbody").on("click", ".edit-record", function () {
            var id = $(this).attr('data-id');
            $.ajax({
                type: "GET",
                url: '@Url.Action("EditCompoundMS2", "Compound")',
                contentType: "application/json; charset=utf-8",
                data: { "MS2MassSpectraKey": id, "databasekey": databasekey },
                datatype: "json",
                success: function (data) {
                    $('.ms2AddEdit').html(data)
                    document.getElementById('submitButton').value = 'Edit';
                },
                error: function () {
                    alert("Data load failed.");
                }
            });
        });

        $(".datatables-mass tbody").on("click", ".delete-record", function () {
            var id = $(this).attr('data-id');
            Swal.fire({
                title: "Are you sure want to delete?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: !0,
                confirmButtonText: "Yes, delete it!",
                customClass: {
                    confirmButton: "btn btn-primary me-3",
                    cancelButton: "btn btn-label-secondary",
                },
                buttonsStyling: !1,
            }).then(function (t) {
                if (t.isConfirmed) {
                    $.ajax({
                        type: "GET",
                        url: '@Url.Action("DeleteCompoundMS2", "Compound")',
                        contentType: "application/json; charset=utf-8",
                        data: { "MS2MassSpectraKey": id },
                        datatype: "json",
                        success: function (data) {
                            t.value &&
                                Swal.fire({
                                    icon: "success",
                                    title: "Deleted!",
                                    text: "Your data has been deleted.",
                                    customClass: { confirmButton: "btn btn-success" },
                                });

                            $('.swal2-confirm').on('click', function () {
                                $('#InstrumentKey').trigger("change");
                            });
                        },
                        error: function () {
                            alert("Data not deleted.");
                        }
                    });
                }

            });
        });
    });
</script>