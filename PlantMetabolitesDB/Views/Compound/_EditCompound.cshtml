                $(".typeahead.compiledBy").typeahead(
                    { hint: !isRtl, highlight: !0, minLength: 1 },
                    {
                        name: "CompiledBy",
                        source:
                            ((s = e),
                                function (e, a) {
                                    var t = [],
                                        o = new RegExp(e, "i");
                                    $.each(s, function (e, a) {
                                        o.test(a) && t.push(a);
