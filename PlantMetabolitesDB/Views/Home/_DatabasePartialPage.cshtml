@model  IEnumerable<PlantMetabolitesDB.ViewModel.AvailableDatabaseViewModel>
<style>
    .show-more {
        line-height: 47px;
        padding: 11px 42px;
        margin: 3px;
        position: relative;
        text-align: center;
        display: inline;
        background: #f54857;
        text-decoration: none;
        color: #ffffff;
        font-size: 14px;
        font-weight: 500;
        border: 0;
        -webkit-transition: all .3s ease-out;
        -moz-transition: all .3s ease-out;
        transition: all .3s ease-out;
    }
</style>
<div class="centres-border">
    <h2>Available Plant Families <span></span></h2>
</div>
<div class="available-database">
    @if (Model != null)
    {
        for (int i = 0; i < Model.Take(11).Count(); i++)
        {
            <article>@Model.ElementAt(i).DatabaseName<span>@Model.ElementAt(i).Count</span></article>
        }


        if (Model.Count() > 11)
        {
            <a href="/AvailableDatabase" class="show-more">More Database ...</a>
        }

    }

</div>

