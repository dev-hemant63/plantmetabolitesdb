@{
    ViewBag.Title = "Welcome to Plant Metabolites Database";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="bg-video-wrap" style="display:none;">
    <div id="demo" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/Content/images/slider1.jpg" alt="" class="d-block">
                <div class="container">
                    <div class="carousel-grid">
                        <div class="carousel-caption">
                            <div class="right-text">
                                <h2>
                                    Welcome to<br>
                                    <b> Plant </b> <b>Metabolites Database</b>
                                </h2>
                                <aside class="titleborder-grid"> <span class="titleborder-grid-radius"></span> <span class="titleborder-grid-line2"></span> </aside>
                                <p>A library of MS/MS spectrum of naturally occurring compounds (Natural products).</p>
                                <a href="@Url.Action("Index", "Overview")" class="readmore">Know More</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/Content/images/slider2.jpg" alt="" class="d-block">
                <div class="container">
                    <div class="carousel-grid">
                        <div class="carousel-caption">
                            <div class="right-text">
                                <h2>
                                    Welcome to<br>
                                    <b> Plant </b> <b>Metabolites Database</b>
                                </h2>
                                <aside class="titleborder-grid"> <span class="titleborder-grid-radius"></span> <span class="titleborder-grid-line2"></span> </aside>
                                <p>A library of MS/MS spectrum of naturally occurring compounds (Natural products).</p>
                                <a href="@Url.Action("Index", "Overview")" class="readmore">Know More</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/Content/images/slider3.jpg" alt="" class="d-block">
                <div class="container">
                    <div class="carousel-grid">
                        <div class="carousel-caption">
                            <div class="right-text">
                                <h2>
                                    Welcome to<br>
                                    <b> Plant </b> <b>Metabolites Database</b>
                                </h2>
                                <aside class="titleborder-grid"> <span class="titleborder-grid-radius"></span> <span class="titleborder-grid-line2"></span> </aside>
                                <p>A library of MS/MS spectrum of naturally occurring compounds (Natural products).</p>
                                <a href="@Url.Action("Index", "Overview")" class="readmore">Know More</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/Content/images/slider4.jpg" alt="" class="d-block">
                <div class="container">
                    <div class="carousel-grid">
                        <div class="carousel-caption">
                            <div class="right-text">
                                <h2>
                                    Welcome to<br>
                                    <b> Plant </b> <b>Metabolites Database</b>
                                </h2>
                                <aside class="titleborder-grid"> <span class="titleborder-grid-radius"></span> <span class="titleborder-grid-line2"></span> </aside>
                                <p>A library of MS/MS spectrum of naturally occurring compounds (Natural products).</p>
                                <a href="@Url.Action("Index", "Overview")" class="readmore">Know More</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Left and right controls/icons -->
        <button class="carousel-control-prev" type="button" data-bs-target="#demo" data-bs-slide="prev"> <span class="carousel-control-prev-icon"></span> </button>
        <button class="carousel-control-next" type="button" data-bs-target="#demo" data-bs-slide="next"> <span class="carousel-control-next-icon"></span> </button>
    </div>
</div>

<section class="baaner-image">
    <div class="container">
        @{
            Html.RenderPartial("_AboutPartialPage");
        }
    </div>
</section>
<section class="news-grid">
    <div class="container">
        <div class="row">
            <!--Breaking box-->
            <div class="col-md-12 col-xs-12 col-lg-12 news-ticker">
            </div>
            @*@{
                Html.RenderPartial("_NewsTickerPartialPage");
            }*@
            <!--end breaking content-->
        </div>
    </div>
</section>
<div class="container">
<section class="centres-grid">
    <div class="container">
        <div class="row">
            @{
                Html.RenderPartial("_GeneralSearchPartialPage");
            }
            <div class="col-md-1 col-12">
                <span class="vertical-border"></span>
            </div>
            @{
                Html.RenderPartial("_MSBasedSearchPartialPage");
            }
        </div>
    </div>
</section>
</div>
<section class="service-grid">
    <div class="container">
        <div class="row">
            @*@{
            Html.RenderPartial("_DatabasePartialPage");
        }*@
            <div class="col-md-6 col-12 av-database"></div>
            <div class="col-md-3 col-12 lt-downloads"></div>
                @*@{
                Html.RenderPartial("_DownloadsPartialPage");
            }*@
                @{
                    Html.RenderPartial("_UtilitiesPartialPage");
                }
            </div>
        </div>
</section>
@section Scripts
{
    <script>
        $(function () {
            $.ajax({
                 type: "GET",
                 url: '@Url.Action("GetAvailableDatabase", "Home")',
                 contentType: "application/json; charset=utf-8",
                 data: {},
                 datatype: "json",
                 success: function (data) {
                     $('.av-database').html(data)
                 },
                 error: function () {
                   alert("Data load failed.");
                 }
            });
            $.ajax({
                 type: "GET",
                 url: '@Url.Action("GetNewsTicker", "Home")',
                 contentType: "application/json; charset=utf-8",
                 data: {},
                 datatype: "json",
                 success: function (data) {
                     $('.news-ticker').html(data)
                 },
                 error: function () {
                   alert("Data load failed.");
                 }
            });
            $.ajax({
                     type: "GET",
                     url: '@Url.Action("GetDownloads", "Home")',
                     contentType: "application/json; charset=utf-8",
                     data: {},
                     datatype: "json",
                     success: function (data) {
                         $('.lt-downloads').html(data)
                     },
                     error: function () {
                       alert("Data load failed.");
                     }
            });
    });
    </script>
}