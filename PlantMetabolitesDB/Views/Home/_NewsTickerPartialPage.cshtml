
@model  IEnumerable<PlantMetabolitesDB.ViewModel.NewsTickerViewModel>
<style>
    .ticker_item {
        display: inline-block;
        padding: 0 2rem;
        color: #ff0000;
    }
</style>
<div class="marquee-top">
    <div class="breaking-caret note"><img src="~/Content/images/news-icon.svg" alt=""> </div>
    <marquee class="marquee marquee-scroll" direction="left" onmouseover="stop()" onmouseout="start()">
        @if (Model != null)
        {
            for (int i = 0; i < Model.Count(); i++)
            {
                <div class="ticker_item">@Model.ElementAt(i).Title</div>
            }
        }
    </marquee>
</div>

