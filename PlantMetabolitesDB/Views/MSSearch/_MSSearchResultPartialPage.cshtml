<script>
    $(function () {
        $('#hspor').hide();
        $('#footerprint').hide();
    });
    $(function () {
        $(".view-record").click(function () {
            $.blockUI({
                message:
                    '<div class="spinner-border text-white" role="status"></div>',
                css: { backgroundColor: "transparent", border: "0" },
                overlayCSS: { opacity: 0.5 },
            });
            var id = $(this).attr('data-id');
            // var options = { "backdrop": "static", keyboard: true };
            $.ajax({
                type: "GET",
                url: "/GeneralSearch/CompoundSummary",
                contentType: "application/json; charset=utf-8",
                data: { "CompoundKey": id },
                datatype: "json",
                success: function (data) {
                    $.unblockUI();
                    $('.compound-preview-body').html(data)
                    $('#search-result').hide();
                    $('#compound-summary').show();
                    $('#search-filter').hide();
                },
                error: function () {
                    $.unblockUI();
                    alert("Data load failed.");
                }
            });
        });
    });
</script>
<script>
    $(function () {
        $('#ResultPrintContainer').hide();

        $(".view-data-coverage").click(function () {
            $.blockUI({
                message:
                    '<div class="spinner-border text-white" role="status"></div>',
                css: { backgroundColor: "transparent", border: "0" },
                overlayCSS: { opacity: 0.5 },
            });
            var compoundKey = $(this).attr('data-compoundKey');
            var mAnnotationType = $(this).attr('data-matchedAnnotationType');
            var mMassSpectraKey = $(this).attr('data-matchedMassSpectraKey');
            var mInputIndex = $(this).attr('data-matchedInputIndex');
            $.ajax({
                type: "GET",
                url: "/MSSearch/GetDataCoverage",
                contentType: "application/json; charset=utf-8",
                data: { "CompoundKey": compoundKey, "matchedAnnotationType": mAnnotationType, "matchedMassSpectraKey": mMassSpectraKey, "matchedInputIndex": mInputIndex },
                datatype: "json",
                success: function (data) {
                    $.unblockUI();
                    $('.data-coverage-body').html(data)
                    $('#search-result').hide();
                    $('#compound-summary').hide();
                    $('#search-filter').hide();
                    $('#data-coverage').show();
                },
                error: function () {
                    $.unblockUI();
                    alert("Data load failed.");
                }
            });
        });
    });

    function PrintSearchResult() {
        $('#lblDatabase1').text($('#hdDatabase').text());
        $('#lblInstrument1').text($('#hdInstrument').text());
        $('#lblPrecursorIon1').text($('#hdlPrecursorIon').text());
        $('#lblPolarity1').text($('#hdPolarity').text());

        var printContents = document.getElementById('ResultPrintContainer');
        var url = location.origin + location.pathname;
        var printWindow = window.open(url, '', '');
        printWindow.document.write('<html><head><title>Search By MS/MS Ion</title>');
        printWindow.document.write('<link href="../Content/css/print.css" rel="stylesheet" media="print" />');
        printWindow.document.write('</head><body>');
        printWindow.document.write(printContents.innerHTML);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        setTimeout(function () {
            printWindow.print();
            printWindow.close();
        }, 500);
    }
</script>