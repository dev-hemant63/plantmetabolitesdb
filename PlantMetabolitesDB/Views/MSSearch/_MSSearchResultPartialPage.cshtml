@model IEnumerable<PlantMetabolitesDB.ViewModel.MassSpectra_MSAdv_Search>

<div class="col-md-12 col-sm-12 col-xs-12 mt-2">
    <div class="card mb-2">
        <h6 class="card-header"><strong>Search Criteria</strong></h6>
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <td><strong>Database</strong></td>
                    <td><span id="lblDatabase"></span></td>
                    <td><strong>Instrument</strong></td>
                    <td><span id="lblInstrument"></span></td>
                </tr>
                <tr>
                    <td><strong>Polarity</strong></td>
                    <td><span id="lblPolarity"></span></td>
                    <td><strong>Precursor Ion</strong></td>
                    <td><span id="lblPrecursorIon"></span></td>
                </tr>
            </table>
        </div>
    </div>
    <div class="card mb-2">
        <h6 class="card-header">
            <strong>MS Ion Search Result</strong><br />
            <span> Click on the Name / Molecular Weight / Formula to see more data.</span>
        </h6>
        <div class="card-body">
            <div class="table-responsive">
                <table width="100%" align="center" border="0" cellspacing="0" cellpadding="0" class="table table-bordered table-striped">
                    <colgroup>
                        <col style="width: 24%">
                        <col style="width: 8%">
                        <col style="width: 8%">
                        <col style="width: 15%">
                        <col style="width: 15%">
                        <col style="width: 8%">
                        <col style="width: 12%">
                        <col style="width: 10%">

                    </colgroup>
                    <thead>
                        <tr>
                            <th>
                                <strong>Query</strong>
                            </th>
                            <th>
                                <strong>QM</strong>
                            </th>

                            <th>
                                <strong>M.W.</strong>
                            </th>
                            <th>
                                <strong>Name</strong>
                            </th>
                            <th>
                                <strong>Formula</strong>
                            </th>
                            <th>
                                <strong>Score</strong>
                            </th>
                            <th>
                                <strong>Hit</strong>
                            </th>
                            <th>
                                <strong>Data Coverage</strong>
                            </th>
                        </tr>

                    </thead>
                    <tbody>
                        @if (Model.Count() > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @item.Query
                                    </td>
                                    <td>
                                        @item.Data_QM
                                    </td>
                                    <td>
                                        <a href="javascript:;" class="view-record" data-id='@item.Data_CompoundKey'>@item.Data_MW</a>
                                    </td>
                                    <td>
                                        <a href="javascript:;" class="view-record" data-id='@item.Data_CompoundKey'>@item.Data_Name</a>
                                    </td>
                                    <td>
                                        <a href="javascript:;" class="view-record" data-id='@item.Data_CompoundKey' >@item.Data_Formula</a>
                                    </td>
                                    <td>
                                        @Math.Round(item.Data_mz_MatchFactor,2)
                                    </td>
                                    <td>
                                        @item.Data_MHit
                                    </td>
                                    <td>
                                       
                                        <a href="javascript:void(0);" title="Click to View" class="view-data-coverage btn btn-sm btn-primary" 
                                          data-matchedAnnotationType='@item.matchedAnnotationType' data-matchedMassSpectraKey='@item.matchedMassSpectraKey' 
                                           data-matchedInputIndex='@item.matchedInputIndex' data-compoundKey='@item.Data_CompoundKey'>View</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

