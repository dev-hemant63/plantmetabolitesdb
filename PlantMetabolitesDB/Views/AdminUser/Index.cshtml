
@{
    ViewBag.Title = "Admin Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h4 class="py-3 breadcrumb-wrapper mb-2">Admin Users List</h4>

<!-- Users Table -->
<div class="card" id="adminUsersTable">
    <div class="card-datatable table-responsive">
        <table class="datatables-adminusers table border-top">
            <thead>
                <tr>
                    <th></th>
                    <th></th>
                    @*<th>User Type</th>*@
                    <th>Code</th>
                    <th>Name</th>
                    <th>UserName</th>
                    <th>Password</th>
                    <th>Country</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<!--/ Users Table -->
<div class="admin-users-form-body" id="adminUsersForm">

</div>
@section Scripts
{
    <script>
        $(function () {
            LoadTable();


        });

