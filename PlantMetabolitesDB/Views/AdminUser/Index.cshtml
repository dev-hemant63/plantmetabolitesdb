                                //return '<span class="text-nowrap">' + r + "</span>";
                            },
                        },

                        {
                            targets: -1,
                            searchable: !1,
                            title: "Actions",
                            orderable: !1,
                            render: function (e, a, t, s) {
                                var r = t.IsActive == true ? "<a href='javascript:void(0)' data-isactive='De-Activate' data-id=" + t.UserKey + " class='active-deactive'><span class='btn btn-xs btn-outline-dark m-1'>Deactivate</span></a>" : "<a href='javascript:void(0)' data-id=" + t.UserKey + " data-isactive='Activate' class='active-deactive'><span class='btn btn-xs btn-outline-dark m-1'>Activate</span></a>"
                                var lnk = '<span class="text-nowrap">'
                                lnk = lnk + '<button class="edit-record btn btn-sm btn-icon me-2" data-id=' + t.UserKey + ' title="Edit"> <i class="bx bx-edit"></i></button>'
                                lnk = lnk + '<button class="delete-record btn btn-sm btn-icon me-2" data-id=' + t.UserKey + ' title="Delete"><i class="bx bx-trash"></i></button>'
                               // lnk = lnk + '<button class="reset-password btn btn-sm btn-icon" data-id=' + t.UserKey + ' title="Reset Password"><i class="fa-solid fa-key"></i></button>'
                                lnk = lnk + r + '</span>';

                                return lnk;
                            },
                        },
                    ],
                    order: [[1, "desc"]],
                    //dom: '<"row mx-1"<"col-sm-12 col-md-3" l><"col-sm-12 col-md-9"<"dt-action-buttons text-xl-end text-lg-start text-md-end text-start d-flex align-items-center justify-content-md-end justify-content-center flex-wrap me-1"<"me-3"f>B>>>t<"row mx-2"<"col-sm-12 col-md-6"i><"col-sm-12 col-md-6"p>>',
                    dom: '<"row ms-2 me-3"<"col-12 col-md-6 d-flex align-items-center justify-content-center justify-content-md-start gap-2"l<"dt-action-buttons text-xl-end text-lg-start text-md-end text-start mt-md-0 mt-3"B>><"col-12 col-md-6 d-flex align-items-center justify-content-end flex-column flex-md-row pe-3 gap-md-2"f<"adminuser_status mb-3 mb-md-0">>>t<"row mx-2"<"col-sm-12 col-md-6"i><"col-sm-12 col-md-6"p>>',

                    language: {
                        sLengthMenu: "_MENU_",
                        search: "Search",
                        searchPlaceholder: "Search..",
                    },
                    buttons: [
                        {
                            text: '<i class="bx bx-plus me-0 me-lg-2"></i><span class="d-none d-lg-inline-block">Add Admin User</span>',
                            className: "add-new btn btn-primary mb-3 mb-md-0",
                            init: function (e, a, t) {
                                $(a).removeClass("btn-secondary");
                            },
                        },
                    ],
                    //responsive: {
                    //    details: {
                    //        display: $.fn.dataTable.Responsive.display.modal({
                    //            header: function (e) {
                    //                return "Details of " + e.data().Name;
                    //            },
                    //        }),
                    //        type: "column",
                    //        renderer: function (e, a, t) {
                    //            t = $.map(t, function (e, a) {
                    //                return "" !== e.title
                    //                    ? '<tr data-dt-row="' +
                    //                    e.rowIndex +
                    //                    '" data-dt-column="' +
                    //                    e.columnIndex +
                    //                    '"><td>' +
                    //                    e.title +
                    //                    ":</td> <td>" +
                    //                    e.data +
                    //                    "</td></tr>"
                    //                    : "";
                    //            }).join("");
                    //            return !!t && $('<table class="table"/><tbody />').append(t);
                    //        },
                    //    },
                    //},
                    initComplete: function () {
                        this.api()
                            .columns(7)
                            .every(function () {
                                var a = this,
                                    t = $(
                                        '<select id="AdminUserStatus" class="form-select text-capitalize"><option value=""> Select Status </option></select>'
                                    )
                                        .appendTo(".adminuser_status")
                                        .on("change", function () {
                                            var e = $.fn.dataTable.util.escapeRegex($(this).val());
                                            a.search(e ? "^" + e + "$" : "", !0, !1).draw();
                                        });
                                a.data()
                                    .unique()
                                    .sort()
                                    .each(function (e, a) {
                                        t.append(
                                            '<option value="' +
                                            e +
                                            '" class="text-capitalize">' +
                                            e +
                                            "</option>"
                                        );
                                    });
                            });
                    },
                })),

                $(".datatables-adminusers tbody").on("click", ".active-deactive", function () {
                    var id = $(this).attr('data-id');
                    var statustext = $(this).attr('data-isactive');
                    Swal.fire({
                        title: "Are you sure want to " + statustext + "?",
                        text: "You won't be able to revert this!",
                        icon: "warning",
                        showCancelButton: !0,
                        confirmButtonText: "Yes, " + statustext + " it!",
                        customClass: {
                            confirmButton: "btn btn-primary me-3",
                            cancelButton: "btn btn-label-secondary",
                        },
                        buttonsStyling: !1,
                    }).then(function (t) {
                        if (t.isConfirmed) {
                            $.ajax({
                                type: "GET",
                                url: '@Url.Action("ActivateDeActivate", "AdminUser")',
                                contentType: "application/json; charset=utf-8",
                                data: { "UserKey": id },
                                datatype: "json",
                                success: function (data) {
                                    var txtmsg = statustext == "Activate" ? "Activated" : "De-Activated"
                                    t.value &&
                                        Swal.fire({
                                            icon: "success",
                                            title: txtmsg,
                                            text: "Your data has been " + txtmsg + ".",
                                            customClass: { confirmButton: "btn btn-success" },
                                        });

                                    $('.swal2-confirm').on('click', function () { LoadTable() });
                                },
                                error: function () {
                                    alert("Error Occured!");
                                }
                            });
                        }

                    });
                }),

                $(".datatables-adminusers tbody").on("click", ".delete-record", function () {
                    var id = $(this).attr('data-id');
                    Swal.fire({
                        title: "Are you sure want to delete?",
                        text: "You won't be able to revert this!",
                        icon: "warning",
                        showCancelButton: !0,
                        confirmButtonText: "Yes, delete it!",
                        customClass: {
                            confirmButton: "btn btn-primary me-3",
                            cancelButton: "btn btn-label-secondary",
                        },
                        buttonsStyling: !1,
                    }).then(function (t) {
                        if (t.isConfirmed) {
                            $.ajax({
                                type: "GET",
                                url: '@Url.Action("DeleteAdminUser", "AdminUser")',
                                contentType: "application/json; charset=utf-8",
                                data: { "UserKey": id },
                                datatype: "json",
                                success: function (data) {
                                    t.value &&
                                        Swal.fire({
                                            icon: "success",
                                            title: "Deleted!",
                                            text: "Your data has been deleted.",
                                            customClass: { confirmButton: "btn btn-success" },
                                        });

                                    $('.swal2-confirm').on('click', function () { LoadTable() });
                                },
                                error: function () {
                                    alert("Data not deleted.");
                                }
                            });
                        }

                    });
                }),

                $(".add-new").on("click", function () {
                    $.ajax({
                        type: "GET",
                        url: '@Url.Action("AddAdminUsers", "AdminUser")',
                        contentType: "application/json; charset=utf-8",
                        data: {},
                        datatype: "json",
                        success: function (data) {
                            $('.admin-users-form-body').html(data)
                            $('#adminUsersTable').hide();
                            $('#adminUsersForm').show();
                        },
                        error: function () {
                            alert("Data load failed.");
                        }
                    });
                }),

                $(".datatables-adminusers tbody").on("click", ".edit-record", function () {
                        var id = $(this).attr('data-id');
                        $.ajax({
                            type: "GET",
                            url: '@Url.Action("EditAdminUsers", "AdminUser")',
                            contentType: "application/json; charset=utf-8",
                            data: { "UserKey": id },
                            datatype: "json",
                            success: function (data) {
                                $('.admin-users-form-body').html(data)
                                $('#adminUsersTable').hide();
                                $('#adminUsersForm').show();
                            },
                            error: function () {
                                alert("Data load failed.");
                            }
                        });
                    }),
                @*$(".datatables-adminusers tbody").on("click", ".reset-password", function () {
                    var id = $(this).attr('data-id');
                    Swal.fire({
                        title: "Are you sure want to reset password?",
                        text: "You won't be able to revert this!",
                        icon: "warning",
                        showCancelButton: !0,
                        confirmButtonText: "Yes, Reset it!",
                        customClass: {
                            confirmButton: "btn btn-primary me-3",
                            cancelButton: "btn btn-label-secondary",
                        },
                        buttonsStyling: !1,
                    }).then(function (t) {
                        if (t.isConfirmed) {
                            $.ajax({
                                type: "GET",
                                url: '@Url.Action("ResetPassword", "AdminUser")',
                                contentType: "application/json; charset=utf-8",
                                data: { "UserKey": id },
                                datatype: "json",
                                success: function (data) {
                                    t.value &&
                                        Swal.fire({
                                            icon: "success",
                                            title: "Reset Password!",
                                            text: "Your Password has been Reset.",
                                            customClass: { confirmButton: "btn btn-success" },
                                        });

                                    $('.swal2-confirm').on('click', function () { LoadTable() });
                                },
                                error: function () {
                                    alert("Password not reset");
                                }
                            });
                        }
                    });

                }),*@

                $(".datatables-adminusers tbody").on("click", ".showhidepassword", function () {
                    //$(this).attr('type', 'text'); 
                    const x = $(":input").attr('type') === 'password' ? 'text' : 'password';
                    if (x.type === "password") {
                        x.type = "text";
                    } else {
                        x.type = "password";
                    }
                    $(this).attr("type", type);

                });

                setTimeout(() => {
                    $(".dataTables_filter .form-control").removeClass("form-control-sm"),
                        $(".dataTables_length .form-select").removeClass("form-select-sm");

                }, 300);
    }

    </script>


}