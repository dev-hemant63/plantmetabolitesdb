
@model  PlantMetabolitesDB.ViewModel.AductIonMassViewModel

<div class="col-md-12 col-sm-12 col-xs-12">
    <br>
    <div class="table-responsive">
        <table width="100%" align="center" border="0" cellspacing="0" cellpadding="0" class="table table-bordered table-striped">
            <colgroup>
                <col style="width: 20%">
                <col style="width: 20%">
                <col style="width: 10%">
                <col style="width: 25%">
                <col style="width: 25%">
            </colgroup>
            <tbody>
                @if (Model != null)
                {
                    <tr>
                        <td>
                            <strong>Ion Name</strong>
                        </td>
                        <td>
                            <strong>Ion Mass</strong>
                        </td>
                        <td align="center">
                            <strong>Charge</strong>
                        </td>
                        <td nowrap="nowrap" align="right">
                            <strong>Adduct Ion Mass</strong>
                        </td>
                        <td align="right" nowrap="nowrap">
                            <strong>▲(M+ : Adduct)</strong>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="7"><strong>1. Positive-Ion Mode</strong></td>
                    </tr>

                    foreach (var item in Model.AductIonMassPositives)
                    {

                        <tr class="clsPositive whitebgColor color3" style="height:25px;">
                            <td valign="middle" class="normal_eng">
                                @item.IonName
                            </td>
                            <td valign="middle" class="normal_eng" nowrap="nowrap">
                                @item.IonMass
                            </td>
                            <td valign="middle" class="normal_eng" align="center">
                                @item.Charge
                                <input type="text" id="txtIonMult" name="txtIonMult" readonly="readonly" style="border: 0px solid #000000; width:10px; display: none;" value="@item.AductIonMass">
                                <input type="text" id="txtIonMass" name="txtIonMass" readonly="readonly" style="border: 0px solid #000000; width:80px; text-align:right; display: none;" value="@item.PositiveMass">
                            </td>
                            <td id="tdAdductIonMass" valign="middle" align="right">
                                <input type="text" id="txtAdductIonMass" name="txtAdductIonMass" style="text-align:right" disabled>
                            </td>
                            <td valign="middle" align="right">
                                <input type="text" id="txtAdduct" name="txtAdduct" style="text-align:right" disabled>
                            </td>
                        </tr>


                    }
                    <tr>
                        <td colspan="4"><strong>2. Negative-Ion Mode</strong></td>
                        <td align="right" nowrap="nowrap">
                            <strong>▲(M- : Adduct)</strong>
                        </td>
                    </tr>

                    foreach (var item in Model.AductIonMassNegatives)
                    {

                        <tr class="clsNegative whitebgColor color3" style="height:25px;">
                            <td valign="middle" class="normal_eng">
                                @item.IonName
                            </td>
                            <td valign="middle" class="normal_eng" nowrap="nowrap">
                                @item.IonMass
                            </td>
                            <td valign="middle" class="normal_eng" align="center">
                                @item.Charge
                                <input type="text" id="txtIonMult" name="txtIonMult" readonly="readonly" style="border: 0px solid #000000; width:10px; display: none;" value="@item.AductIonMass">
                                <input type="text" id="txtIonMass" name="txtIonMass" readonly="readonly" style="border: 0px solid #000000; width:80px; text-align:right; display: none;" value="@item.NegativeMass">
                            </td>


                            <td id="tdAdductIonMass" valign="middle" align="right">
                                <input type="text" id="txtAdductIonMass" name="txtAdductIonMass" style="text-align:right" disabled>
                            </td>
                            <td valign="middle" align="right">
                                <input type="text" id="txtAdduct" name="txtAdduct" style="text-align:right" disabled>
                            </td>
                        </tr>


                    }
                }
            </tbody>
        </table>
    </div>
</div>



