
@{
    ViewBag.Title = "FAQ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model  IEnumerable<PlantMetabolitesDB.ViewModel.FAQViewModel>
<div class="breadcrumb-grid">
    <div class="container">
        <div class="row">
            <div class="col-md-12 col-sm-12 col-xs-12">
                <h3 class="header_title">FAQ</h3>
                <ol class="breadcrumb">
                    <li><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="active">FAQ </li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="inner-grid">
    <div class="container">
        <div class="row">

            <div class="col-md-12 col-xs-12">
                <div class="accordion" id="myAccordion">
                    @if (Model != null)
                    {
                        for (int i = 0; i < Model.Count(); i++)
                        {


                            if (i == 0)
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading_@i" style="font-size: 32px;">
                                        <button type="button" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapse_@i">
                                            @Model.ElementAt(i).Title

                                        </button>
                                    </h2>

                                    <div id="collapse_@i" class="accordion-collapse collapse show" data-bs-parent="#myAccordion">
                                        <div class="card-body">
                                            <p style="font-size: 14px;">
                                                @Model.ElementAt(i).Description
                                            </p>
                                            @if (Model.ElementAt(i).UploadedFileName != null)
                                            {
                                                if (Model.ElementAt(i).fileExtension == "pdf")
                                                {
                                                    <a href="~/UploadedFiles/FAQs/@Model.ElementAt(i).UploadedFileName" target="_blank" title="Click to view file">
                                                        <i class="fa fa-file-pdf-o" aria-hidden="true"></i>
                                                    </a>

                                                }
                                                else
                                                {
                                                    <a href="~/UploadedFiles/FAQs/@Model.ElementAt(i).UploadedFileName" target="_blank" title="Click to view file" class="blue-btn">
                                                        <i class="fa fa-file-text" aria-hidden="true"></i>
                                                    </a>
                                                }

                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading_@i" style="font-size: 32px;">
                                        <button type="button" class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#collapse_@i">
                                            @Model.ElementAt(i).Title

                                        </button>
                                    </h2>

                                    <div id="collapse_@i" class="accordion-collapse collapse" data-bs-parent="#myAccordion">
                                        <div class="card-body">
                                            <p style="font-size: 14px;">
                                                @Model.ElementAt(i).Description
                                            </p>
                                            @if (Model.ElementAt(i).UploadedFileName != null)
                                            {
                                                if (Model.ElementAt(i).fileExtension == "pdf")
                                                {
                                                    <a href="~/UploadedFiles/FAQs/@Model.ElementAt(i).UploadedFileName" target="_blank" title="Click to view file">
                                                        <i class="fa fa-file-pdf-o" aria-hidden="true"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a href="~/UploadedFiles/FAQs/@Model.ElementAt(i).UploadedFileName" target="_blank" title="Click to view file"  class="blue-btn">
                                                        <i class="fa fa-file-text" aria-hidden="true"></i>
                                                    </a>
                                                }


                                            }

                                        </div>
                                    </div>
                                </div>
                            }

                        }
                    }

                </div>
            </div>

        </div>
    </div>
</section>
@section Scripts
{
    <script>
                            //$(function ($) {
                            //    $('#myAccordion').find('.accordion-item #collapse_0').addClass("show");
                            //    $('#myAccordion').find('.accordion-item #heading_1').find('.accordion-button').addClass("collapsed");
                            //});
    </script>

}