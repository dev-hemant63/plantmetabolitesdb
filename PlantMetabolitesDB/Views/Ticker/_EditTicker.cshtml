

@model PlantMetabolitesDB.ViewModel.TickerViewModel
<style>
    .file-button-hide-show {
        float: right;
    }
</style>
<div class="text-center mb-4">
    <h3>Edit Ticker</h3>
</div>

@using (Html.BeginForm("", "", FormMethod.Post, new { @id = "editTickerForm", @class = "row", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(d => d.TickerKey)
    <div class="col-12 mb-3">
        @Html.LabelFor(d => d.MessageType, new { @class = "form-label" })
        @Html.DropDownListFor(e => e.MessageType, new SelectList(Model.MessageTypes, "Value", "Text"), new { @class = "form-select" })
    </div>

    <div class="col-12 mb-3">
        @Html.LabelFor(d => d.Title, new { @class = "form-label" })
        @Html.TextAreaFor(e => e.Title, new { @class = "form-control", @placeholder = "Title", @autofocus = "autofocus", @rows = "3" })
    </div>
    <div class="col-12 mb-3">
        @Html.LabelFor(d => d.UploadedFileName, new { @class = "form-label" })
        <input class="form-control" type="file" id="UploadedImageFile" name="UploadedImageFile">
        @if (Model.UploadedFileName != null)
        {
            @Html.HiddenFor(d => d.UploadedFileName)
            <div class="file-button-hide-show">
                <a href="~/UploadedFiles/Ticker/@Model.UploadedFileName" target="_blank" class="btn btn-sm btn-secondary mt-2"><i class="bx bx-show-alt"></i> View</a>
                @*<button type="button" name="removeUploadedFile" id="removeUploadedFile" class="btn btn-sm btn-danger mt-2"><i class="bx bx-trash"></i> Remove</button>*@

            </div>
        }

    </div>
    <div class="col-12 text-center demo-vertical-spacing">
        <input type="submit" value="Update" class="btn btn-primary me-sm-3 me-1" id="submitButton" name="submitButton" />
        <button type="reset" class="btn btn-label-secondary" data-bs-dismiss="modal" aria-label="Close">Close</button>
    </div>
}

<script>
    $(function (e) {
        //  const dd = document.getElementById("MessageType");
        const submitButton = document.getElementById('submitButton');
        const a = document.getElementById("editTickerForm");
        const fv = FormValidation.formValidation(
            a, {
            fields: {
                MessageType: {
                    validators: { notEmpty: { message: "Please select message type" } },
                },
                Title: {
                    validators: {
                        notEmpty: { message: "Please enter title" },
                        regexp: {
                            regexp: /^[^<%>]+$/,
                            message: 'Invalid character not allowed'
                        },
                    },
                },
                UploadedImageFile: {
                    validators: {
                        // notEmpty: { message: "Please select the file" },
                        file: {
                            extension: 'pdf',
                            type: 'application/pdf',
                            maxSize: 1024 * 1024,
                            message: 'The file must be in pdf format and must not exceed 1MB in size',
                        },
                    },
                },
            },
            plugins: {
                trigger: new FormValidation.plugins.Trigger(),
                bootstrap5: new FormValidation.plugins.Bootstrap5({
                    eleValidClass: "",
                    rowSelector: ".col-12",
                }),
                submitButton: new FormValidation.plugins.SubmitButton(),
                autoFocus: new FormValidation.plugins.AutoFocus(),
                //excluded: new FormValidation.plugins.Excluded({
                //    excluded: function (field, ele, eles) {
                //        const selectedMessageType = a.querySelector('[name="MessageType"]');
                //        const messagetype = selectedMessageType ? selectedMessageType.value : '';
                //        return (field === 'UploadedImageFile' && messagetype !== '2') || (field === 'MessageType' && messagetype === '2');
                //    },
                //}),
            },
        });

        fv.on('core.form.valid', function () {
            // Disable the submit button
            submitButton.setAttribute('disabled', true);
            document.getElementById('submitButton').value = 'Updating...';
            var form = $("#editTickerForm").get(0);
            var formData = new FormData(form);
            $.ajax({
                url: "/Ticker/EditTicker",
                type: "POST",
                dataType: 'json',
                //contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                cache: false,
                contentType: false,
                processData: false,
                data: formData,
                success: function (response) {
                    //$('#tickerModal').modal('hide');
                    //LoadTable();
                    Swal.fire({
                        icon: "success",
                        title: "Updated",
                        text: "Data updated successfully.",
                        customClass: { confirmButton: "btn btn-success" },
                    });

                    $('.swal2-confirm').on('click', function () {
                        $('#tickerModal').modal('hide');
                        LoadTable();
                    });
                },
                error: function (response) {

                }
            });
            // Do something else such as sending the form to back-end via Ajax request
            // ...
        });

        //fv.on('core.form.validating', function (event) {
        //    // `event.formValidation` is the FormValidation instance
        //    // which is the same as `fv`
        //    if (dd.selectedIndex == 2) {
        //        fv.enableValidator("UploadedImageFile", "notEmpty")
        //    }
        //});

        a.querySelector('[name="MessageType"]').addEventListener('change', function (e) {
            fv.revalidateField('UploadedImageFile');
        });

        //a.querySelector('[name="removeUploadedFile"]').addEventListener('click', function (e) {
        //    fv.enableValidator("UploadedImageFile","notEmpty")
        //});


    });
</script>