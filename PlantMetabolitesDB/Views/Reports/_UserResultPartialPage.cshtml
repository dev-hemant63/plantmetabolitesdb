@model IEnumerable<PlantMetabolitesDB.ViewModel.UsersViewModel>

<div class="card-datatable table-responsive">
    <table class="datatables-users table border-top">
        <thead>
            <tr>
                <th>Code</th>
                <th>User Name</th>
                <th>Full Name</th>
                @*<th>Address</th>*@
                <th>Phone</th>
                <th>Mobile</th>
                <th>Country</th>
                <th>Organization</th>
                <th>Affiliation</th>
                <th>Status</th>
                <th>Registration Date</th>
                <th>Login Count</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count() > 0)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.Username</td>
                        <td>@item.FullName</td>
                        @*<td>@item.Address</td>*@
                        <td>@item.Phone</td>
                        <td>@item.Mobile</td>
                        <td>@item.CountryName</td>
                        <td>@item.OrganizationTypeName</td>
                        <td>@item.Affiliation</td>
                        <td>@item.StatusName</td>
                        <td>@item.CreatedOn.Value.ToString("dd/MM/yyyy")</td>
                        <td>@item.cntLogin</td>
                    </tr>
                }
            }

        </tbody>
    </table>
</div>
<script>
    $('.datatables-users').DataTable({

    });
</script>