                    //                    : "";
                    //            }).join("");
                    //            return !!t && $('<table class="table"/><tbody />').append(t);
                    //        },
                    //    },
                    //},
                    initComplete: function () {
                        this.api()
                            .columns(5)
                            .every(function () {
                                var a = this,
                                    t = $(
                                        '<select id="AnnotationStatus" class="form-select text-capitalize"><option value=""> Select Status </option></select>'
                                    )
                                        .appendTo(".annotation_status")
                                        .on("change", function () {
                                            var e = $.fn.dataTable.util.escapeRegex($(this).val());
                                            a.search(e ? "^" + e + "$" : "", !0, !1).draw();
                                        });
