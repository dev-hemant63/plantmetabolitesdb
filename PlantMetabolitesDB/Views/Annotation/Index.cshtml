                                @*var lnk = '<span class="text-nowrap"><button class="edit-record btn btn-sm btn-icon me-2" "data-bs-toggle": "modal" data-bs-target="#annotationModal" data-id=' + t.AnnotationKey + '><i class="bx bx-edit"></i></button>'
