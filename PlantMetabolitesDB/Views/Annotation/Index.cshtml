@model IEnumerable<PlantMetabolitesDB.ViewModel.AnnotationViewModel>
@{
    ViewBag.Title = "Annotation";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<h4 class="py-3 breadcrumb-wrapper mb-2">Annotation List</h4>
<!-- Annotation Table -->
<div class="card">
    <div class="card-datatable table-responsive">
        <table class="datatables-annotation table border-top">
            <thead>
                <tr>
                    <th></th>
                    <th></th>
                    <th>Annotation Name</th>
                    <th>Polarity</th>
                    <th>Annotation Type</th>
                    @*<th>Created Date</th>*@
                    <th>Status</th>
                    <th width="16%">Actions</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<!--/ Annotation Table -->

<div class="modal fade" id="annotationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-3 p-md-5">
            <button type="button" class="btn-close btn-pinned" data-bs-dismiss="modal" aria-label="Close"></button>
            <div class="modal-body">

            </div>
        </div>
    </div>
</div>

@section Scripts
{

    <script>
