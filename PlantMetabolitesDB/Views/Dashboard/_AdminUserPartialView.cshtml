        <div class="table-responsive">
            <table class="table border-top">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Country</th>
                        <th>Organization</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">

                    @if (Model.Count() > 0)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@item.Code</td>
                                <td class="text-nowrap">@item.FullName</td>
                                <td class="text-nowrap">@item.CountryName</td>
                                <td class="text-nowrap">@item.OrganizationTypeName</td>
                                <td class="text-nowrap">
                                    @if (item.IsActive)
                                    {
                                        <span class='badge rounded-pill bg-label-success'>@item.StatusName</span>
                                    }
                                    else
                                    {
                                        <span class='badge rounded-pill bg-label-danger'>@item.StatusName</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

